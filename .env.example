# FinCalc Pro — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Server
PORT=3001
NODE_ENV=production

# CORS — set to your frontend domain in production
ALLOWED_ORIGIN=https://yourdomain.com

# Admin panel key (change this to a long random secret in production)
ADMIN_KEY=change-this-to-a-long-random-secret

# ============================================================
# MARKET DATA PROVIDERS (choose one or use mock)
# ============================================================

# Option A: TrueData (https://truedata.in)
# TRUEDATA_USER=your_username
# TRUEDATA_PASS=your_password

# Option B: GlobalDataFeeds (https://globaldatafeeds.in)
# GDF_API_KEY=your_key

# Option C: RapidAPI / IndianAPI (affordable)
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOST=latest-stock-price.p.rapidapi.com

# Option D: Apify scraper (prototyping)
# APIFY_TOKEN=your_apify_token

# ============================================================
# EMAIL (for contact form)
# ============================================================
# RESEND_API_KEY=re_xxxx
# CONTACT_TO_EMAIL=hello@yourdomain.com

# ============================================================
# ANALYTICS (optional, only loads after cookie consent)
# ============================================================
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
